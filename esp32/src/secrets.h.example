// WiFi credentials — COPY THIS FILE to secrets.h and fill in your network.
//
//   cp src/secrets.h.example src/secrets.h
//
// secrets.h is gitignored, so your real password is never committed. Leaving secrets.h
// absent (or WIFI_SSID empty) disables the WiFi optimization and the firmware polls over
// BLE continuously — see the WiFi section in README.md.
#pragma once

#define WIFI_SSID "your-network-name"
#define WIFI_PASS "your-network-password"
